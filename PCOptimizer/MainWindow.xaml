<Window x:Class="PCOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Optimizer" Height="740" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}" MinWidth="450" MinHeight="550">

    <Window.Resources>
        <!-- Rounded button template com transição suave -->
        <Style x:Key="RunButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.85" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.25"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.65" Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card de otimização com hover animado (leve zoom + borda destacada) -->
        <Style x:Key="OptCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Card5Border}"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1.012" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1.012" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Grupo expansível: cabeçalho com seta, conteúdo recolhido por padrão -->
        <Style x:Key="GroupExpanderStyle" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Content="{TemplateBinding Header}"
                                          Cursor="Hand" Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="6,10,6,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="Arrow" Text="▶" FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <ContentPresenter Grid.Column="1" Margin="8,0,12,0"
                                                                  VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" Height="1"
                                                        Background="{DynamicResource BorderColor}"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="Arrow"
                                                                Storyboard.TargetProperty="RenderTransform.Angle"
                                                                To="90" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="Arrow"
                                                                Storyboard.TargetProperty="RenderTransform.Angle"
                                                                To="0" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Arrow" Property="Foreground"
                                                        Value="{DynamicResource TextPrimary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Fade-in suave ao abrir a janela -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Accent gradient strip (acompanha o tema) ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource AccentStripBg}"/>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBg}" Padding="24,18,24,16"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#667EEA" Offset="0"/>
                                <GradientStop Color="#A78BFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="⚡" FontSize="24"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PC Optimizer" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <Border Background="{DynamicResource BadgeBg}" CornerRadius="20"
                                    Padding="10,3" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtVersion" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BadgeFg}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Otimize seu PC com um clique" FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnScreenshot" Content="📸"
                            Width="40" Height="40" FontSize="18"
                            Style="{StaticResource RunButtonStyle}"
                            Background="{DynamicResource ButtonSecondaryBg}"
                            Foreground="{DynamicResource ButtonSecondaryFg}"
                            BorderThickness="0" Margin="0,0,6,0"
                            Cursor="Hand" Click="BtnScreenshot_Click"
                            ToolTip="Capturar área da tela"/>
                    <Button x:Name="BtnBrightness"
                            Height="44" Padding="14,0"
                            Style="{StaticResource RunButtonStyle}"
                            Background="{DynamicResource RunButtonBg}"
                            Foreground="White"
                            BorderThickness="0" Margin="0,0,6,0"
                            Cursor="Hand" Click="BtnBrightnessHeader_Click"
                            ToolTip="Abrir Brilho e Contraste (janela flutuante)">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.6" Color="#8B5CF6"/>
                        </Button.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💡" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Brilho" FontSize="13" FontWeight="Bold"
                                       Foreground="White" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnThemeToggle" Content="{DynamicResource ThemeToggleIcon}"
                            VerticalAlignment="Center"
                            Width="40" Height="40" FontSize="18"
                            Style="{StaticResource RunButtonStyle}"
                            Background="{DynamicResource ButtonSecondaryBg}"
                            Foreground="{DynamicResource ButtonSecondaryFg}"
                            BorderThickness="0"
                            Cursor="Hand" Click="BtnThemeToggle_Click"
                            ToolTip="Alternar tema claro/escuro"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Select All bar ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBg}" Padding="24,10"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkSelectAll" VerticalAlignment="Center"
                              Checked="ChkSelectAll_Checked" Unchecked="ChkSelectAll_Unchecked"/>
                    <TextBlock Text="Selecionar Tudo" Margin="8,0,0,0"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="{DynamicResource BadgeBg}" CornerRadius="10" Padding="10,4">
                    <TextBlock x:Name="TxtSelected" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource BadgeFg}"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ Optimization List ═══ -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="OptList" Margin="16,4,16,10">
                <!-- ═══ Grupo: LIMPEZA ═══ -->
                <Expander Style="{StaticResource GroupExpanderStyle}" IsExpanded="False" Margin="0,2,0,0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧹" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="LIMPEZA" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondary}" Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="(9)" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="6,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,2,0,4">
                    <!-- Limpar Temporários -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkTemp" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card1Bg}" Margin="10,0,14,0">
                                <TextBlock Text="🗑️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Limpar Temporários" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Remove arquivos temporários do sistema e navegadores" FontSize="10"
                                           Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusTemp" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Limpar Disco -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkDisk" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card2Bg}" Margin="10,0,14,0">
                                <TextBlock Text="💾" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Limpar Disco" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Remove caches, logs e dumps do sistema" FontSize="10"
                                           Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusDisk" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Limpar Lixeira -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkRecycleBin" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card3Bg}" Margin="10,0,14,0">
                                <TextBlock Text="♻️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Limpar Lixeira" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Esvazia a Lixeira do Windows permanentemente" FontSize="10"
                                           Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusRecycleBin" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Cache Windows Update -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkWinUpdateCache" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card5Bg}" Margin="10,0,14,0">
                                <TextBlock Text="🔄" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Limpar Cache do Windows Update" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Remove downloads antigos de atualizações (pode liberar GBs)" FontSize="10"
                                           Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusWinUpdateCache" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Cache de Miniaturas -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkThumbnails" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card6Bg}" Margin="10,0,14,0">
                                <TextBlock Text="🖼️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Limpar Cache de Miniaturas" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Limpa thumbnails e ícones acumulados/corrompidos" FontSize="10"
                                           Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusThumbnails" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Cache de Shaders -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkShaderCache" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card2Bg}" Margin="10,0,14,0">
                                <TextBlock Text="💠" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Limpar Cache de Shaders" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Limpa shaders DirectX/NVIDIA/AMD — resolve stuttering após atualizar o driver" FontSize="10"
                                           Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusShaderCache" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Otimizar SSD (TRIM) -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkSsdTrim" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card4Bg}" Margin="10,0,14,0">
                                <TextBlock Text="⚡" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Otimizar SSD (TRIM)" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Executa o retrim para manter o SSD rápido" FontSize="10"
                                           Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusSsdTrim" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Desfragmentar Disco -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkDefrag" IsChecked="False" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card3Bg}" Margin="10,0,14,0">
                                <TextBlock Text="💿" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Desfragmentar Disco" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Otimiza o disco C: (pode demorar alguns minutos)" FontSize="10"
                                           Foreground="#F9E2AF" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusDefrag" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Desativar Hibernação -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkHibernation" IsChecked="False" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card7Bg}" Margin="10,0,14,0">
                                <TextBlock Text="🛏️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Desativar Hibernação" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Apaga o hiberfil.sys e libera vários GB (remove o hibernar)" FontSize="10"
                                           Foreground="#F9E2AF" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusHibernation" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>
                    </StackPanel>
                </Expander>

                <!-- ═══ Grupo: SISTEMA E DESEMPENHO ═══ -->
                <Expander Style="{StaticResource GroupExpanderStyle}" IsExpanded="False" Margin="0,2,0,0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="SISTEMA E DESEMPENHO" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondary}" Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="(13)" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="6,0,0,0"

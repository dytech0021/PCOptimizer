<Window x:Class="PCOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Optimizer" Height="740" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}" MinWidth="450" MinHeight="550">

    <Window.Resources>
        <!-- Rounded button template -->
        <Style x:Key="RunButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tool card with hover highlight -->
        <Style x:Key="ToolCardStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource Card7Border}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Accent gradient strip ═══ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#667EEA" Offset="0"/>
                    <GradientStop Color="#A78BFA" Offset="0.5"/>
                    <GradientStop Color="#F472B6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBg}" Padding="24,18,24,16"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#667EEA" Offset="0"/>
                                <GradientStop Color="#A78BFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="⚡" FontSize="24"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PC Optimizer" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <Border Background="{DynamicResource BadgeBg}" CornerRadius="8"
                                    Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="v1.8.0" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BadgeFg}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Otimize seu PC com um clique" FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnBrightness" Content="🌞"
                            Width="48" Height="48" FontSize="22"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnBrightnessHeader_Click"
                            ToolTip="Abrir Brilho e Contraste"/>
                    <Button x:Name="BtnThemeToggle" Content="{DynamicResource ThemeToggleIcon}"
                            VerticalAlignment="Center"
                            Width="40" Height="40" FontSize="18"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnThemeToggle_Click"
                            ToolTip="Alternar tema claro/escuro"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Select All bar ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBg}" Padding="24,10"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkSelectAll" VerticalAlignment="Center"
                              Checked="ChkSelectAll_Checked" Unchecked="ChkSelectAll_Unchecked"/>
                    <TextBlock Text="Selecionar Tudo" Margin="8,0,0,0"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="{DynamicResource BadgeBg}" CornerRadius="10" Padding="10,4">
                    <TextBlock x:Name="TxtSelected" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource BadgeFg}"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ Optimization List ═══ -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="OptList" Margin="16,4,16,10">

                <!-- ─── LIMPEZA ─── -->
                <Grid Margin="6,8,6,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🧹" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="LIMPEZA" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondary}" Margin="8,0,12,0"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Height="1" Background="{DynamicResource BorderColor}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Limpar Temporários -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkTemp" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card1Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🗑️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Limpar Temporários" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Remove arquivos temporários do sistema e navegadores" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusTemp" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Limpar Disco -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkDisk" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card2Bg}" Margin="10,0,14,0">
                            <TextBlock Text="💾" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Limpar Disco" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Remove caches, logs e dumps do sistema" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusDisk" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Limpar Lixeira -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkRecycleBin" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card3Bg}" Margin="10,0,14,0">
                            <TextBlock Text="♻️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Limpar Lixeira" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Esvazia a Lixeira do Windows permanentemente" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusRecycleBin" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- ─── SISTEMA ─── -->
                <Grid Margin="6,14,6,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⚙️" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="SISTEMA" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondary}" Margin="8,0,12,0"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Height="1" Background="{DynamicResource BorderColor}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Otimizar Inicialização -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkStartup" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card4Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🚀" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Otimizar Inicialização" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Escolha quais programas iniciam com o Windows" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusStartup" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Serviços do Windows -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkServices" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card5Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🛡️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Serviços do Windows" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Desativa serviços desnecessários para ganhar performance" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusServices" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Otimizar Rede -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkNetwork" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card6Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🌐" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Otimizar Rede" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Limpa cache DNS e otimiza configurações TCP" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusNetwork" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Registro do Windows -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkRegistry" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card1Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🔧" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Registro do Windows" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Aplica tweaks de performance no registro" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusRegistry" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- ─── EXTRAS ─── -->
                <Grid Margin="6,14,6,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🧩" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="EXTRAS" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondary}" Margin="8,0,12,0"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Height="1" Background="{DynamicResource BorderColor}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Desativar Cortana -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkCortana" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card2Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🔇" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Desativar Cortana" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Desativa a Cortana e pesquisa online do Windows" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusCortana" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Desfragmentar Disco -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkDefrag" IsChecked="False" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card3Bg}" Margin="10,0,14,0">
                            <TextBlock Text="💿" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Desfragmentar Disco" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Otimiza o disco C: (pode demorar alguns minutos)" FontSize="10"
                                       Foreground="#F9E2AF" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusDefrag" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- ─── DESEMPENHO ─── -->
                <Grid Margin="6,14,6,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🚀" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="DESEMPENHO" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondary}" Margin="8,0,12,0"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Height="1" Background="{DynamicResource BorderColor}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Plano de Energia -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkPowerPlan" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card4Bg}" Margin="10,0,14,0">
                            <TextBlock Text="⚡" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Plano de Energia Alto Desempenho" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Ativa o modo de máxima performance (ótimo em notebooks)" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusPowerPlan" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Efeitos Visuais -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkVisualEffects" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card5Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🎨" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Otimizar Efeitos Visuais" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Desliga animações e transparências para uma interface mais ágil" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusVisualEffects" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Apps em Segundo Plano -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkBackgroundApps" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card6Bg}" Margin="10,0,14,0">
                            <TextBlock Text="📱" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Desativar Apps em Segundo Plano" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Impede apps da Store de rodarem escondidos consumindo recursos" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusBackgroundApps" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Limpar RAM -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkStandbyRam" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card7Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🧠" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Liberar Memória RAM" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Esvazia o cache de memória dos processos sem reiniciar" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusStandbyRam" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Agendamento de GPU -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkGpuScheduling" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card1Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🖥️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Agendamento de GPU por Hardware" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Ativa o HAGS — pode reduzir latência em jogos (requer reiniciar)" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusGpuScheduling" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- ─── PRIVACIDADE ─── -->
                <Grid Margin="6,14,6,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔒" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="PRIVACIDADE" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondary}" Margin="8,0,12,0"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Height="1" Background="{DynamicResource BorderColor}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Telemetria -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkTelemetry" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card2Bg}" Margin="10,0,14,0">
                            <TextBlock Text="📊" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Desativar Telemetria" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Bloqueia a coleta de dados e diagnóstico da Microsoft" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusTelemetry" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Xbox Game Bar -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkGameBar" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card3Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🎮" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Desativar Xbox Game Bar / DVR" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Desliga a gravação em segundo plano (ganho em jogos)" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusGameBar" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- ─── DISCO ─── -->
                <Grid Margin="6,14,6,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="💽" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="DISCO" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondary}" Margin="8,0,12,0"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Height="1" Background="{DynamicResource BorderColor}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Otimizar SSD (TRIM) -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkSsdTrim" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card4Bg}" Margin="10,0,14,0">
                            <TextBlock Text="⚡" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Otimizar SSD (TRIM)" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Executa o retrim para manter o SSD rápido" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusSsdTrim" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Cache Windows Update -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkWinUpdateCache" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card5Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🔄" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Limpar Cache do Windows Update" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Remove downloads antigos de atualizações (pode liberar GBs)" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusWinUpdateCache" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Cache de Miniaturas -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkThumbnails" IsChecked="True" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card6Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🖼️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Limpar Cache de Miniaturas" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Limpa thumbnails e ícones acumulados/corrompidos" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusThumbnails" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Desativar Hibernação -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkHibernation" IsChecked="False" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card7Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🛏️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Desativar Hibernação" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Apaga o hiberfil.sys e libera vários GB (remove o hibernar)" FontSize="10"
                                       Foreground="#F9E2AF" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusHibernation" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Inicialização Rápida -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkFastStartup" IsChecked="False" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card1Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🚄" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Desativar Inicialização Rápida" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Evita o &quot;desligamento falso&quot; — boots mais limpos e estáveis" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusFastStartup" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- ─── MANUTENÇÃO ─── -->
                <Grid Margin="6,14,6,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🩺" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="MANUTENÇÃO" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondary}" Margin="8,0,12,0"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Height="1" Background="{DynamicResource BorderColor}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Reparar Sistema -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkSystemRepair" IsChecked="False" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card1Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🩺" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Reparar Arquivos do Sistema (SFC + DISM)" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Conserta arquivos corrompidos (pode demorar 5-10 minutos)" FontSize="10"
                                       Foreground="#F9E2AF" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusSystemRepair" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

                <!-- Remover Bloatware -->
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,3" Padding="12,10"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="ChkBloatware" IsChecked="False" VerticalAlignment="Center"
                                  Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                Background="{DynamicResource Card2Bg}" Margin="10,0,14,0">
                            <TextBlock Text="🗑️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Remover Bloatware" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Desinstala apps inúteis (Notícias, Clima, Solitaire, etc.)" FontSize="10"
                                       Foreground="#F9E2AF" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" x:Name="StatusBloatware" Text="—"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Log area ═══ -->
        <Border Grid.Row="4" Margin="16,4,16,6" MaxHeight="90">
            <Border Background="{DynamicResource SurfaceBg}" CornerRadius="10"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <Grid>
                    <Border Width="3" HorizontalAlignment="Left" CornerRadius="2"
                            Margin="8,8,0,8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#667EEA" Offset="0"/>
                                <GradientStop Color="#A78BFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto" Margin="18,8,10,8">
                        <TextBlock x:Name="TxtLog" FontSize="10" Foreground="{DynamicResource LogText}"
                                   TextWrapping="Wrap" Text="Pronto para otimizar."/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>

        <!-- ═══ Footer ═══ -->
        <Border Grid.Row="5" Background="{DynamicResource SurfaceBg}" Padding="20,12,20,14"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ProgressBar x:Name="Progress" Height="4" VerticalAlignment="Top" Margin="0,-12,0,0"
                             Background="{DynamicResource ProgressBg}" Foreground="{DynamicResource ButtonPrimaryBg}"
                             BorderThickness="0" Visibility="Collapsed" Panel.ZIndex="1"/>
                <TextBlock x:Name="TxtProgress" Grid.Row="0" Visibility="Collapsed"
                           FontSize="11" Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <Button x:Name="BtnRun" Grid.Row="1" Style="{StaticResource RunButtonStyle}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        Padding="0,14" FontSize="15" FontWeight="Bold"
                        Background="{DynamicResource ButtonPrimaryBg}" Foreground="{DynamicResource ButtonPrimaryFg}"
                        BorderThickness="0" Cursor="Hand" Click="BtnRun_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Executar Otimizações" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

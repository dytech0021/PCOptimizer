                            <CheckBox Grid.Column="0" x:Name="ChkPowerThrottling" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card5Bg}" Margin="10,0,14,0">
                                <TextBlock Text="⚡" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Desativar Power Throttling" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Impede o Windows de reduzir o clock de processos que julga inativos" FontSize="10"
                                           Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusPowerThrottling" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Otimizações de Tela Cheia -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkFullscreenOpt" IsChecked="False" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card7Bg}" Margin="10,0,14,0">
                                <TextBlock Text="🖥️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Desativar Otimizações de Tela Cheia" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Pode reduzir input lag, mas varia por jogo — teste e reverta se piorar" FontSize="10"
                                           Foreground="#F9E2AF" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusFullscreenOpt" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Precisão do Ponteiro -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkMousePrecision" IsChecked="False" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card1Bg}" Margin="10,0,14,0">
                                <TextBlock Text="🖱️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Desativar Precisão do Ponteiro" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Remove a aceleração do mouse (padrão em FPS) — muda a sensação do cursor" FontSize="10"
                                           Foreground="#F9E2AF" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusMousePrecision" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Isolamento de Núcleo -->
                    <Border Style="{StaticResource OptCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="ChkCoreIsolation" IsChecked="False" VerticalAlignment="Center"
                                      Checked="OptCheckChanged" Unchecked="OptCheckChanged"/>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="12"
                                    Background="{DynamicResource Card2Bg}" Margin="10,0,14,0">
                                <TextBlock Text="🛡️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Desativar Isolamento de Núcleo (HVCI)" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Maior ganho de FPS, porém reduz a segurança do sistema (requer reiniciar)" FontSize="10"
                                           Foreground="#F9E2AF" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" x:Name="StatusCoreIsolation" Text="—"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                        </Grid>
                    </Border>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Log area ═══ -->
        <Border Grid.Row="4" Margin="16,4,16,6" MaxHeight="90">
            <Border Background="{DynamicResource SurfaceBg}" CornerRadius="10"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <Grid>
                    <Border Width="3" HorizontalAlignment="Left" CornerRadius="2"
                            Margin="8,8,0,8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#667EEA" Offset="0"/>
                                <GradientStop Color="#A78BFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto" Margin="18,8,10,8">
                        <TextBlock x:Name="TxtLog" FontSize="10" Foreground="{DynamicResource LogText}"
                                   TextWrapping="Wrap" Text="Pronto para otimizar."/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>

        <!-- ═══ Footer ═══ -->
        <Border Grid.Row="5" Background="{DynamicResource SurfaceBg}" Padding="20,12,20,14"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ProgressBar x:Name="Progress" Height="4" VerticalAlignment="Top" Margin="0,-12,0,0"
                             Background="{DynamicResource ProgressBg}" Foreground="{DynamicResource ButtonPrimaryBg}"
                             BorderThickness="0" Visibility="Collapsed" Panel.ZIndex="1"/>
                <TextBlock x:Name="TxtProgress" Grid.Row="0" Visibility="Collapsed"
                           FontSize="11" Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <Button x:Name="BtnRun" Grid.Row="1" Style="{StaticResource RunButtonStyle}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        Padding="0,16" FontSize="15" FontWeight="Bold"
                        Background="{DynamicResource RunButtonBg}" Foreground="{DynamicResource RunButtonFg}"
                        BorderThickness="0" Cursor="Hand" Click="BtnRun_Click">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.55" Color="#8B5CF6"/>
                    </Button.Effect>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" FontSize="17" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Executar Otimizações" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text=" →" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

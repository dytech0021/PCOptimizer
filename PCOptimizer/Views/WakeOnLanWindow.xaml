<Window x:Class="PCOptimizer.Views.WakeOnLanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wake-on-LAN" Width="440" Height="640"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Margin="10" CornerRadius="12"
            Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" Opacity="0.4" ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho + badge de status -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="📡 Wake-on-LAN" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Ligue o PC remotamente pelo celular via rede local"
                               FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                </StackPanel>
                <Border x:Name="StatusBadge" HorizontalAlignment="Right" VerticalAlignment="Top"
                        CornerRadius="8" Padding="10,4">
                    <TextBlock x:Name="TxtStatusBadge" FontSize="11" FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- Como funciona -->
            <Border Grid.Row="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,14"
                    Background="#0A1E14" BorderBrush="#173D27" BorderThickness="1">
                <TextBlock FontSize="10" Foreground="#6EE7B7" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Como funciona: "/>
                    <Run Text="um app no celular envia um 'magic packet' com o MAC desta placa. O PC recebe pelo cabo Ethernet e liga — mesmo estando desligado, desde que haja energia e o BIOS esteja configurado."/>
                </TextBlock>
            </Border>

            <!-- Placa de rede -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Seletor de adaptador (só aparece quando há 2 ou mais) -->
                <Grid Grid.Row="0" x:Name="MultiAdapterRow" Visibility="Collapsed" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Placa:" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CboAdapter" Grid.Column="1" FontSize="12" Padding="6,4"
                              Background="{DynamicResource SurfaceBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderColor}"
                              SelectionChanged="CboAdapter_SelectionChanged"/>
                </Grid>

                <!-- Nome do adaptador -->
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Adaptador:" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Top" Margin="0,2,0,0"/>
                    <TextBlock x:Name="TxtAdapterName" Grid.Column="1" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" Text="—"/>
                </Grid>

                <!-- MAC address + copiar -->
                <Grid Grid.Row="2" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="MAC:" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtMac" Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center" Text="—"/>
                    <Button x:Name="BtnCopyMac" Grid.Column="2" Content="📋 Copiar" FontSize="11"
                            Padding="10,4" Cursor="Hand"
                            Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            Click="BtnCopyMac_Click"/>
                </Grid>

                <!-- IP local -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="IP local:" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtIp" Grid.Column="1" FontSize="12"
                               FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center" Text="—"/>
                </Grid>
            </Grid>

            <!-- Aviso BIOS -->
            <Border Grid.Row="3" CornerRadius="8" Padding="10,8" Margin="0,0,0,10"
                    Background="#1A1400" BorderBrush="#3A2E00" BorderThickness="1">
                <TextBlock FontSize="10" Foreground="#FCD34D" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="⚙️ BIOS (passo obrigatório uma vez): "/>
                    <Run Text="Reinicie → Entre no BIOS (Del / F2 / F12) → Procure 'Wake on LAN', 'Power On By PCI-E' ou 'ErP Ready' → Ative WoL e DESATIVE ErP/EuP. Salve e reinicie."/>
                    <LineBreak/>
                    <Run FontWeight="SemiBold" Foreground="#FCA5A5" Text="❗ Parou após tirar da tomada? "/>
                    <Run Text="É o ErP/EuP ligado no BIOS: ele corta a energia de standby da placa de rede quando falta luz. DESATIVE 'ErP Ready'/'EuP' no BIOS — sem isso o WoL não sobrevive a um corte de energia. Depois, ligue o PC uma vez e desligue normal para rearmar."/>
                    <LineBreak/>
                    <Run FontWeight="SemiBold" Text="Requer cabo Ethernet: "/>
                    <Run Text="Wi-Fi não funciona de forma confiável."/>
                </TextBlock>
            </Border>

            <!-- App do celular -->
            <Border Grid.Row="4" CornerRadius="8" Padding="10,8" Margin="0,0,0,12"
                    Background="#0D1628" BorderBrush="#1B2E50" BorderThickness="1">
                <TextBlock FontSize="10" Foreground="#93C5FD" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="📱 App no celular: "/>
                    <Run Text="Android: 'Wake On LAN' (Domotz) ou 'WolOn'. iOS: 'Mocha WOL' ou 'RemoteBoot WOL'. Instale, cadastre o MAC acima e o IP do PC na rede local → toque em Ligar."/>
                </TextBlock>
            </Border>

            <!-- Mensagem de feedback -->
            <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TxtMsg" FontSize="11" TextWrapping="Wrap"
                           VerticalAlignment="Top"/>
            </ScrollViewer>

            <!-- Botões -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Fechar" Padding="14,7" Margin="0,0,8,0"
                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        FontSize="12" Cursor="Hand" Click="BtnClose_Click"/>
                <Button x:Name="BtnDiagnose" Content="🔍 Diagnóstico" Padding="14,7" Margin="0,0,8,0"
                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        FontSize="12" Cursor="Hand" Click="BtnDiagnose_Click"/>
                <Button x:Name="BtnEnable" Content="📡 Ativar no Windows" Padding="16,7"
                        Background="{DynamicResource ButtonPrimaryBg}"
                        Foreground="{DynamicResource ButtonPrimaryFg}"
                        BorderThickness="0" FontSize="12" FontWeight="Bold"
                        Cursor="Hand" Click="BtnEnable_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

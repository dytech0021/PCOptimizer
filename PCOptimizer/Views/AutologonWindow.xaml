<Window x:Class="PCOptimizer.Views.AutologonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto-login" Width="420" Height="400"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Margin="10" CornerRadius="12"
            Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" Opacity="0.4" ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho + badge de status -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="🔐 Auto-login ao Iniciar" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Inicia o Windows sem pedir senha (Windows 10 e 11 25H2+)"
                               FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                </StackPanel>
                <Border x:Name="StatusBadge" HorizontalAlignment="Right" VerticalAlignment="Top"
                        CornerRadius="8" Padding="10,4">
                    <TextBlock x:Name="TxtStatusBadge" FontSize="11" FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- Aviso de segurança -->
            <Border Grid.Row="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,14"
                    Background="#181F2A" BorderBrush="#2A3F5A" BorderThickness="1">
                <TextBlock FontSize="10" Foreground="#89B4FA" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Aviso: "/>
                    <Run Text="A senha é armazenada em texto simples no registro do Windows (HKLM), leitura exige privilégio de administrador. Recomendado apenas em PCs de uso pessoal e sem outros usuários com acesso físico."/>
                </TextBlock>
            </Border>

            <!-- Usuário -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Usuário:" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="TxtUsername" Grid.Column="1" FontSize="12" Padding="6,5"
                         Background="{DynamicResource SurfaceBg}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                         VerticalContentAlignment="Center"/>
            </Grid>

            <!-- Senha -->
            <Grid Grid.Row="3" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Senha:" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <PasswordBox x:Name="TxtPassword" Grid.Column="1" FontSize="12" Padding="6,5"
                             Background="{DynamicResource SurfaceBg}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"/>
            </Grid>

            <!-- Dica conta sem senha -->
            <TextBlock Grid.Row="4"
                       Text="Sem senha? Deixe o campo vazio. Para conta Microsoft use a senha da sua conta Microsoft."
                       FontSize="9" Foreground="{DynamicResource TextSecondary}"
                       Margin="80,0,0,14" TextWrapping="Wrap"/>

            <!-- Mensagem de feedback -->
            <TextBlock x:Name="TxtMsg" Grid.Row="5" FontSize="11" TextWrapping="Wrap"
                       VerticalAlignment="Top"/>

            <!-- Botões -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="BtnDisable" Content="🔒 Desativar" Padding="14,7" Margin="0,0,8,0"
                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        FontSize="12" Cursor="Hand" Click="BtnDisable_Click"
                        Visibility="Collapsed"/>
                <Button Content="Fechar" Padding="14,7" Margin="0,0,8,0"
                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        FontSize="12" Cursor="Hand" Click="BtnClose_Click"/>
                <Button x:Name="BtnEnable" Content="🔓 Ativar auto-login" Padding="16,7"
                        Background="{DynamicResource ButtonPrimaryBg}"
                        Foreground="{DynamicResource ButtonPrimaryFg}"
                        BorderThickness="0" FontSize="12" FontWeight="Bold"
                        Cursor="Hand" Click="BtnEnable_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

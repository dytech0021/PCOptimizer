<Window x:Class="PCOptimizer.Views.TaskbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Barra de Tarefas Transparente" Width="440" Height="670"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        Background="Transparent" Topmost="True"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Margin="10" CornerRadius="12"
            Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" Opacity="0.4" ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho -->
            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="🪟 Barra de Tarefas Transparente" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Deixa a barra inferior translúcida — inspirado no TranslucentTB"
                           FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Como funciona -->
            <Border Grid.Row="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,14"
                    Background="#0D1628" BorderBrush="#1B2E50" BorderThickness="1">
                <TextBlock FontSize="10" Foreground="#93C5FD" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Como funciona: "/>
                    <Run Text="o efeito vale enquanto o PC Optimizer estiver aberto (pode ficar minimizado na bandeja). Ao fechar o app, a barra volta ao normal — é assim que funcionam todos os apps desse tipo."/>
                </TextBlock>
            </Border>

            <!-- Modos -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="Estilo" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondary}" Margin="2,0,0,6"/>

                <RadioButton x:Name="RbOff" GroupName="Mode" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"
                             Checked="Mode_Checked">
                    <StackPanel Margin="4,0,0,0">
                        <TextBlock Text="Desligado" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Aparência padrão do Windows" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="RbTransparent" GroupName="Mode" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"
                             Checked="Mode_Checked">
                    <StackPanel Margin="4,0,0,0">
                        <TextBlock Text="Transparente" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Barra de vidro — mostra o papel de parede atrás" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="RbBlur" GroupName="Mode" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"
                             Checked="Mode_Checked">
                    <StackPanel Margin="4,0,0,0">
                        <TextBlock Text="Desfocado (Blur)" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Fundo desfocado translúcido" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="RbAcrylic" GroupName="Mode" Margin="0,0,0,4" Foreground="{DynamicResource TextPrimary}"
                             Checked="Mode_Checked">
                    <StackPanel Margin="4,0,0,0">
                        <TextBlock Text="Acrílico" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Vidro fosco do Windows (efeito acrílico)" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>

            <!-- Escurecimento -->
            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🌑" FontSize="14" VerticalAlignment="Center"/>
                <Slider x:Name="SldTint" Grid.Column="1" Minimum="0" Maximum="255" Margin="8,0,8,0"
                        VerticalAlignment="Center" ValueChanged="SldTint_ValueChanged"/>
                <TextBlock x:Name="TxtTintValue" Grid.Column="2" Text="0%" Width="38" FontSize="12"
                           FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="{DynamicResource ButtonPrimaryBg}"/>
            </Grid>
            <TextBlock Grid.Row="3" Text="Escurecimento (deixa os ícones mais legíveis)"
                       FontSize="9" Foreground="{DynamicResource TextSecondary}"
                       Margin="22,34,0,0" VerticalAlignment="Top"/>

            <!-- Mensagem -->
            <TextBlock x:Name="TxtTbMsg" Grid.Row="4" FontSize="11" TextWrapping="Wrap"
                       VerticalAlignment="Bottom" Margin="0,12,0,0"
                       Foreground="{DynamicResource TextSecondary}"/>

            <!-- Aviso Windows 11 + plano B garantido -->
            <StackPanel Grid.Row="5">
                <Border x:Name="Win11Warn" CornerRadius="8" Padding="10,8" Margin="0,4,0,8"
                        Visibility="Collapsed"
                        Background="#2A1605" BorderBrush="#5A3410" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="10" Foreground="#FCD34D" TextWrapping="Wrap">
                            <Run FontWeight="SemiBold" Text="⚠ Windows 11: "/>
                            <Run Text="a Microsoft bloqueia esse efeito na barra. Se não mudar nada, use o TranslucentTB oficial — ele é feito só pra isso e funciona de forma confiável no Win11."/>
                        </TextBlock>
                        <Button x:Name="BtnTtb" Content="⬇ Instalar TranslucentTB (oficial)"
                                Margin="0,8,0,0" Padding="12,7" FontSize="11" FontWeight="Bold"
                                Cursor="Hand" BorderThickness="0" HorizontalAlignment="Left"
                                Background="#F59E0B" Foreground="#1A1206"
                                Click="BtnTtb_Click"/>
                    </StackPanel>
                </Border>

                <!-- Botões -->
                <Grid Margin="0,4,0,0">
                    <Button x:Name="BtnDiag" Content="🔍 Diagnóstico" Padding="14,7"
                            HorizontalAlignment="Left"
                            Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            FontSize="12" Cursor="Hand" Click="BtnDiag_Click"/>
                    <Button Content="Fechar" Padding="16,7" HorizontalAlignment="Right"
                            Background="{DynamicResource ButtonPrimaryBg}"
                            Foreground="{DynamicResource ButtonPrimaryFg}"
                            BorderThickness="0" FontSize="12" FontWeight="Bold"
                            Cursor="Hand" Click="BtnClose_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Window x:Class="PCOptimizer.Views.BrightnessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Brilho e Contraste" Height="460" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}" ResizeMode="NoResize">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="🌞 Brilho e Contraste" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock x:Name="TxtMonitorCount" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,5,0,0"
                       Text="Detectando monitores..."/>
        </StackPanel>

        <!-- Brilho -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBg}" CornerRadius="10" Padding="20,15" Margin="0,0,0,12"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
            <StackPanel>
                <Grid>
                    <TextBlock Text="☀️ Brilho" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="TxtBrightnessValue" HorizontalAlignment="Right"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ButtonPrimaryBg}" Text="50%"/>
                </Grid>
                <Slider x:Name="SliderBrightness" Minimum="0" Maximum="100" Value="50"
                        Margin="0,10,0,0" IsEnabled="False"
                        ValueChanged="SliderBrightness_ValueChanged"/>
            </StackPanel>
        </Border>

        <!-- Contraste -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBg}" CornerRadius="10" Padding="20,15" Margin="0,0,0,12"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
            <StackPanel>
                <Grid>
                    <TextBlock Text="🌗 Contraste" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="TxtContrastValue" HorizontalAlignment="Right"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ButtonPrimaryBg}" Text="50%"/>
                </Grid>
                <Slider x:Name="SliderContrast" Minimum="0" Maximum="100" Value="50"
                        Margin="0,10,0,0" IsEnabled="False"
                        ValueChanged="SliderContrast_ValueChanged"/>
            </StackPanel>
        </Border>

        <!-- Atalho de Teclado -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBg}" CornerRadius="10" Padding="20,14"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="⌨️ Atalho de Teclado" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="TxtHotkey" FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
                <Button x:Name="BtnSetHotkey" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Content="Alterar Atalho" Padding="15,7"
                        Background="Transparent"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        FontSize="12" Cursor="Hand" Click="BtnSetHotkey_Click"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="5" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TxtStatus" Grid.Column="0" FontSize="11"
                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>

            <Button Grid.Column="1" Content="Minimizar para Bandeja" Padding="20,8"
                    Background="{DynamicResource ButtonPrimaryBg}" Foreground="{DynamicResource ButtonPrimaryFg}"
                    BorderThickness="0" FontSize="13" FontWeight="Bold" Cursor="Hand" Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>

<Window x:Class="PCOptimizer.Views.BrightnessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="310" Height="510"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ScreenshotBtnStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#0EA5E9" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10" CornerRadius="14"
            Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="22" Opacity="0.45" ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="16,14,16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Header arrastável -->
            <Grid Grid.Row="0" Margin="0,0,0,12"
                  MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🌞" FontSize="15" VerticalAlignment="Center"/>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Brilho e Contraste" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="TxtMonitorCount" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Text="Detectando monitores..."/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="📸" Click="BtnScreenshot_Click" Cursor="Hand"
                            Style="{StaticResource ScreenshotBtnStyle}"
                            Width="32" Height="32" FontSize="15" Padding="0"
                            BorderThickness="0" Margin="0,0,6,0"
                            ToolTip="Capturar área da tela"/>
                    <Button x:Name="BtnTimerToggle" Content="⏻" Click="BtnTimerToggle_Click" Cursor="Hand"
                            Style="{StaticResource ScreenshotBtnStyle}"
                            Width="32" Height="32" FontSize="15" Padding="0"
                            BorderThickness="0" Margin="0,0,6,0"
                            ToolTip="Timer para desligar o computador"/>
                    <Button Content="✕" Click="BtnClose_Click" Cursor="Hand"
                            Background="Transparent" BorderThickness="0"
                            FontSize="13" Foreground="{DynamicResource TextSecondary}"
                            Width="26" Height="26"/>
                </StackPanel>
            </Grid>

            <!-- Row 1: Painel dinâmico de monitores -->
            <ScrollViewer Grid.Row="1" MaxHeight="200"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,0,0,12">
                <StackPanel x:Name="PnlMonitors"/>
            </ScrollViewer>

            <!-- Row 2: Presets -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="Presets (clique direito para editar)" FontSize="9"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" Opacity="0.7"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnPreset1" Grid.Column="0" Cursor="Hand"
                            Margin="0,0,4,0" Padding="0,8"
                            Background="#2D1B4E" Foreground="#CBA6F7" BorderThickness="1"
                            BorderBrush="#45375A"
                            Click="Preset1_Click" MouseRightButtonUp="Preset1_Edit">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtPreset1Icon" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtPreset1Name" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtPreset1Values" FontSize="9" Opacity="0.7" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnPreset2" Grid.Column="1" Cursor="Hand"
                            Margin="2,0,2,0" Padding="0,8"
                            Background="#1B3A4E" Foreground="#89B4FA" BorderThickness="1"
                            BorderBrush="#2A4A5E"
                            Click="Preset2_Click" MouseRightButtonUp="Preset2_Edit">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtPreset2Icon" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtPreset2Name" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtPreset2Values" FontSize="9" Opacity="0.7" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnPreset3" Grid.Column="2" Cursor="Hand"
                            Margin="4,0,0,0" Padding="0,8"
                            Background="#1B4E2D" Foreground="#A6E3A1" BorderThickness="1"
                            BorderBrush="#2A5E3A"
                            Click="Preset3_Click" MouseRightButtonUp="Preset3_Edit">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtPreset3Icon" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtPreset3Name" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtPreset3Values" FontSize="9" Opacity="0.7" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Row 3: Divider -->
            <Border Grid.Row="3" Height="1"
                    Background="{DynamicResource BorderColor}"
                    Margin="0,0,0,10"/>

            <!-- Row 4: Luz Noturna toggle -->
            <Grid Grid.Row="4" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🌙" FontSize="15" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Luz Noturna" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <CheckBox x:Name="ChkNightLight" Grid.Column="2" VerticalAlignment="Center"
                          Checked="ChkNightLight_Checked" Unchecked="ChkNightLight_Unchecked"/>
            </Grid>

            <!-- Row 5: Luz Noturna slider -->
            <Grid Grid.Row="5" Margin="0,0,0,12" x:Name="NightLightPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔥" FontSize="13" VerticalAlignment="Center" Opacity="0.7"/>
                <Slider x:Name="SliderNightLight" Grid.Column="1"
                        Minimum="10" Maximum="100" Value="40"
                        VerticalAlignment="Center"
                        ValueChanged="SliderNightLight_ValueChanged"/>
                <TextBlock x:Name="TxtNightLightValue" Grid.Column="2"
                           Text="40%" FontSize="12" FontWeight="Bold"
                           Foreground="#F9E2AF"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Row 6: Luz Noturna Windows toggle -->
            <Grid Grid.Row="6" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🌙" FontSize="15" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Luz Noturna (Windows)" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <CheckBox x:Name="ChkWinNightLight" Grid.Column="2" VerticalAlignment="Center"
                          Checked="ChkWinNightLight_Checked" Unchecked="ChkWinNightLight_Unchecked"/>
            </Grid>

            <!-- Row 7: Luz Noturna Windows slider (colapsável) -->
            <Grid Grid.Row="7" Margin="0,0,0,12" x:Name="WinNightLightPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔆" FontSize="13" VerticalAlignment="Center" Opacity="0.7"/>
                <Slider x:Name="SliderWinNightLight" Grid.Column="1"
                        Minimum="0" Maximum="100" Value="50"
                        VerticalAlignment="Center"
                        ValueChanged="SliderWinNightLight_ValueChanged"/>
                <TextBlock x:Name="TxtWinNightLightValue" Grid.Column="2"
                           Text="50%" FontSize="12" FontWeight="Bold"
                           Foreground="#F9E2AF"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Row 8: Timer de desligamento (colapsável) -->
            <StackPanel Grid.Row="8" x:Name="TimerPanel" Visibility="Collapsed" Margin="0,0,0,12">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="⏻" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Desligar o PC" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock x:Name="TxtTimerStatus" Grid.Column="2" FontSize="11" FontWeight="Bold"
                               Foreground="#F38BA8" VerticalAlignment="Center"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="15min" Grid.Column="0" Tag="15" Click="TimerPreset_Click" Cursor="Hand"
                            Margin="0,0,3,0" Padding="0,7" FontSize="11"
                            Background="#1B3A4E" Foreground="#89B4FA" BorderThickness="1" BorderBrush="#2A4A5E"/>
                    <Button Content="30min" Grid.Column="1" Tag="30" Click="TimerPreset_Click" Cursor="Hand"
                            Margin="3,0,3,0" Padding="0,7" FontSize="11"
                            Background="#1B3A4E" Foreground="#89B4FA" BorderThickness="1" BorderBrush="#2A4A5E"/>
                    <Button Content="1h" Grid.Column="2" Tag="60" Click="TimerPreset_Click" Cursor="Hand"
                            Margin="3,0,3,0" Padding="0,7" FontSize="11"
                            Background="#1B3A4E" Foreground="#89B4FA" BorderThickness="1" BorderBrush="#2A4A5E"/>
                    <Button Content="2h" Grid.Column="3" Tag="120" Click="TimerPreset_Click" Cursor="Hand"
                            Margin="3,0,0,0" Padding="0,7" FontSize="11"
                            Background="#1B3A4E" Foreground="#89B4FA" BorderThickness="1" BorderBrush="#2A4A5E"/>
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="⏱️" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtTimerCustom" Grid.Column="1" FontSize="11"
                             VerticalAlignment="Center" VerticalContentAlignment="Center"
                             Margin="6,0,6,0" Padding="6,4"
                             Background="{DynamicResource SurfaceBg}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                             ToolTip="Minutos personalizados"/>
                    <Button Content="OK" Grid.Column="2" Click="TimerCustom_Click" Cursor="Hand"
                            Padding="12,5" FontSize="11" Margin="0,0,4,0"
                            Background="#1B4E2D" Foreground="#A6E3A1" BorderThickness="1" BorderBrush="#2A5E3A"/>
                    <Button x:Name="BtnTimerCancel" Content="Cancelar" Grid.Column="3" Click="TimerCancel_Click" Cursor="Hand"
                            Padding="10,5" FontSize="11" Visibility="Collapsed"
                            Background="#4E1B1B" Foreground="#F38BA8" BorderThickness="1" BorderBrush="#5E2A2A"/>
                </Grid>
            </StackPanel>

            <!-- Row 9: Divider -->
            <Border Grid.Row="9" Height="1"
                    Background="{DynamicResource BorderColor}"
                    Margin="0,0,0,10" x:Name="Divider2"/>

            <!-- Row 10: Atalho e status -->
            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⌨️ " FontSize="11"/>
                        <TextBlock x:Name="TxtHotkey" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtStatus" FontSize="10"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button x:Name="BtnSetHotkey" Grid.Column="1"
                        Content="Alterar" Padding="10,5"
                        Background="Transparent"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        FontSize="11" Cursor="Hand" Click="BtnSetHotkey_Click"/>
            </Grid>

        </Grid>
    </Border>
</Window>

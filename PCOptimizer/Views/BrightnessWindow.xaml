<Window x:Class="PCOptimizer.Views.BrightnessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="310" Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <!-- Margem externa dá espaço para a sombra renderizar -->
    <Border Margin="10" CornerRadius="14"
            Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="22" Opacity="0.45" ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="16,14,16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header arrastável -->
            <Grid Grid.Row="0" Margin="0,0,0,14"
                  MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🌞" FontSize="15" VerticalAlignment="Center"/>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Brilho e Contraste" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="TxtMonitorCount" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Text="Detectando monitores..."/>
                    </StackPanel>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="BtnClose_Click" Cursor="Hand"
                        Background="Transparent" BorderThickness="0"
                        FontSize="13" Foreground="{DynamicResource TextSecondary}"
                        Width="26" Height="26"/>
            </Grid>

            <!-- Brilho -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="☀️" FontSize="15" VerticalAlignment="Center"/>
                <Slider x:Name="SliderBrightness" Grid.Column="1"
                        Minimum="0" Maximum="100" Value="50"
                        VerticalAlignment="Center" IsEnabled="False"
                        ValueChanged="SliderBrightness_ValueChanged"/>
                <TextBlock x:Name="TxtBrightnessValue" Grid.Column="2"
                           Text="50%" FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource ButtonPrimaryBg}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Contraste -->
            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🌗" FontSize="15" VerticalAlignment="Center"/>
                <Slider x:Name="SliderContrast" Grid.Column="1"
                        Minimum="0" Maximum="100" Value="50"
                        VerticalAlignment="Center" IsEnabled="False"
                        ValueChanged="SliderContrast_ValueChanged"/>
                <TextBlock x:Name="TxtContrastValue" Grid.Column="2"
                           Text="50%" FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource ButtonPrimaryBg}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Divisor -->
            <Border Grid.Row="3" Height="1"
                    Background="{DynamicResource BorderColor}"
                    Margin="0,0,0,10"/>

            <!-- Atalho e status -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⌨️ " FontSize="11"/>
                        <TextBlock x:Name="TxtHotkey" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtStatus" FontSize="10"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button x:Name="BtnSetHotkey" Grid.Column="1"
                        Content="Alterar" Padding="10,5"
                        Background="Transparent"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        FontSize="11" Cursor="Hand" Click="BtnSetHotkey_Click"/>
            </Grid>

        </Grid>
    </Border>
</Window>

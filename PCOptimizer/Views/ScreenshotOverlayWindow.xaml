<Window x:Class="PCOptimizer.Views.ScreenshotOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#50000000"
        Cursor="Cross">
    <Grid>
        <Canvas x:Name="SelectionCanvas"
                Background="Transparent"
                MouseDown="Canvas_MouseDown"
                MouseMove="Canvas_MouseMove"
                MouseUp="Canvas_MouseUp">
            <Rectangle x:Name="SelectionRect"
                       Stroke="#4FC3F7" StrokeThickness="2"
                       Fill="#204FC3F7"
                       Visibility="Collapsed"/>
        </Canvas>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,24,0,0"
                    IsHitTestVisible="False">
            <Border Background="#CC1A1A2E" CornerRadius="10" Padding="18,10">
                <TextBlock Text="Arraste para selecionar a área  •  ESC para cancelar"
                           Foreground="White" FontSize="13" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>

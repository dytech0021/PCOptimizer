<Window x:Class="PCOptimizer.Views.PresetEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Preset" Width="300" Height="250"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Margin="10" CornerRadius="12"
            Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" Opacity="0.4" ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="✏️ Editar Preset" FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

            <!-- Nome -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Nome:" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtName" Grid.Column="1" FontSize="12" Padding="6,4"
                         Background="{DynamicResource SurfaceBg}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"/>
            </Grid>

            <!-- Brilho -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="38"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Brilho:" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                <Slider x:Name="SliderBrightness" Grid.Column="1" Minimum="0" Maximum="100"
                        VerticalAlignment="Center" ValueChanged="SliderBrightness_Changed"/>
                <TextBlock x:Name="TxtBrightness" Grid.Column="2" FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource ButtonPrimaryBg}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Contraste -->
            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="38"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Contraste:" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                <Slider x:Name="SliderContrast" Grid.Column="1" Minimum="0" Maximum="100"
                        VerticalAlignment="Center" ValueChanged="SliderContrast_Changed"/>
                <TextBlock x:Name="TxtContrast" Grid.Column="2" FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource ButtonPrimaryBg}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Botões -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Cancelar" Padding="14,6" Margin="0,0,8,0"
                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        FontSize="12" Cursor="Hand" Click="BtnCancel_Click"/>
                <Button Content="✅ Salvar" Padding="14,6"
                        Background="{DynamicResource ButtonPrimaryBg}" Foreground="{DynamicResource ButtonPrimaryFg}"
                        BorderThickness="0" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="WindowBg" Color="#F0F2F8"/>
    <SolidColorBrush x:Key="SurfaceBg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>

    <!-- Faixa de destaque no topo -->
    <LinearGradientBrush x:Key="AccentStripBg" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#667EEA" Offset="0"/>
        <GradientStop Color="#A78BFA" Offset="0.5"/>
        <GradientStop Color="#F472B6" Offset="1"/>
    </LinearGradientBrush>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#1A202C"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#718096"/>
    <SolidColorBrush x:Key="TextTertiary" Color="#A0AEC0"/>
    <SolidColorBrush x:Key="LogText" Color="#4A5568"/>
    <SolidColorBrush x:Key="Placeholder" Color="#CBD5E0"/>

    <!-- Buttons -->
    <LinearGradientBrush x:Key="ButtonPrimaryBg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5B8DEF" Offset="0"/>
        <GradientStop Color="#7C3AED" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ButtonPrimaryFg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonSecondaryBg" Color="#EDF2F7"/>
    <SolidColorBrush x:Key="ButtonSecondaryFg" Color="#2D3748"/>
    <SolidColorBrush x:Key="ButtonSuccessBg" Color="#38A169"/>
    <SolidColorBrush x:Key="ButtonSuccessFg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ProgressBg" Color="#E2E8F0"/>

    <!-- Badge -->
    <SolidColorBrush x:Key="BadgeBg" Color="#EBF4FF"/>
    <SolidColorBrush x:Key="BadgeFg" Color="#4A6FA5"/>
    <SolidColorBrush x:Key="ListItemBg" Color="#F7FAFC"/>

    <!-- Icon card gradients (soft pastel) -->
    <LinearGradientBrush x:Key="Card1Bg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFB8B8" Offset="0"/>
        <GradientStop Color="#FFA07A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Card2Bg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#B5C9F5" Offset="0"/>
        <GradientStop Color="#C9B5F5" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Card3Bg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFE4A0" Offset="0"/>
        <GradientStop Color="#FFB347" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Card4Bg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#B5EAD7" Offset="0"/>
        <GradientStop Color="#82CFC2" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Card5Bg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D4B5F5" Offset="0"/>
        <GradientStop Color="#BCA0F0" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Card6Bg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#B5E8F5" Offset="0"/>
        <GradientStop Color="#7BC8E8" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Card7Bg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#B5F5E4" Offset="0"/>
        <GradientStop Color="#7ADED0" Offset="1"/>
    </LinearGradientBrush>

    <!-- Card borders -->
    <SolidColorBrush x:Key="Card1Border" Color="#FFB8B8"/>
    <SolidColorBrush x:Key="Card2Border" Color="#B5C9F5"/>
    <SolidColorBrush x:Key="Card3Border" Color="#FFE4A0"/>
    <SolidColorBrush x:Key="Card4Border" Color="#B5EAD7"/>
    <SolidColorBrush x:Key="Card5Border" Color="#D4B5F5"/>
    <SolidColorBrush x:Key="Card6Border" Color="#B5E8F5"/>
    <SolidColorBrush x:Key="Card7Border" Color="#B5F5E4"/>

    <!-- Run button gradient -->
    <LinearGradientBrush x:Key="RunButtonBg" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#5B8DEF" Offset="0"/>
        <GradientStop Color="#7C3AED" Offset="0.5"/>
        <GradientStop Color="#EC4899" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="RunButtonFg" Color="#FFFFFF"/>

    <!-- Preset buttons -->
    <SolidColorBrush x:Key="Preset1Bg" Color="#F5F0FF"/>
    <SolidColorBrush x:Key="Preset1Fg" Color="#7C3AED"/>
    <SolidColorBrush x:Key="Preset1Border" Color="#D8B4FE"/>
    <SolidColorBrush x:Key="Preset2Bg" Color="#EFF6FF"/>
    <SolidColorBrush x:Key="Preset2Fg" Color="#3B82F6"/>
    <SolidColorBrush x:Key="Preset2Border" Color="#BFDBFE"/>
    <SolidColorBrush x:Key="Preset3Bg" Color="#F0FDF4"/>
    <SolidColorBrush x:Key="Preset3Fg" Color="#16A34A"/>
    <SolidColorBrush x:Key="Preset3Border" Color="#BBF7D0"/>

    <!-- Theme toggle icon -->
    <sys:String x:Key="ThemeToggleIcon" xmlns:sys="clr-namespace:System;assembly=mscorlib">🌙</sys:String>

</ResourceDictionary>

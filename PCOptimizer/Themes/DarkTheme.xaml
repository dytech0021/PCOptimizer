<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="WindowBg" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="SurfaceBg" Color="#181825"/>
    <SolidColorBrush x:Key="BorderColor" Color="#313244"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#CDD6F4"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#9CA0B0"/>
    <SolidColorBrush x:Key="TextTertiary" Color="#7F8497"/>
    <SolidColorBrush x:Key="LogText" Color="#A6ADC8"/>
    <SolidColorBrush x:Key="Placeholder" Color="#585B70"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonPrimaryBg" Color="#89B4FA"/>
    <SolidColorBrush x:Key="ButtonPrimaryFg" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="ButtonSecondaryBg" Color="#45475A"/>
    <SolidColorBrush x:Key="ButtonSecondaryFg" Color="#CDD6F4"/>
    <SolidColorBrush x:Key="ButtonSuccessBg" Color="#A6E3A1"/>
    <SolidColorBrush x:Key="ButtonSuccessFg" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="ProgressBg" Color="#313244"/>

    <!-- Badge -->
    <SolidColorBrush x:Key="BadgeBg" Color="#45475A"/>
    <SolidColorBrush x:Key="BadgeFg" Color="#A6ADC8"/>
    <SolidColorBrush x:Key="ListItemBg" Color="#313244"/>

    <!-- Cards (muted dark pastels) -->
    <SolidColorBrush x:Key="Card1Bg" Color="#3D2A2E"/>
    <SolidColorBrush x:Key="Card1Border" Color="#5A3D43"/>
    <SolidColorBrush x:Key="Card2Bg" Color="#2A3344"/>
    <SolidColorBrush x:Key="Card2Border" Color="#3D4D66"/>
    <SolidColorBrush x:Key="Card3Bg" Color="#3D3527"/>
    <SolidColorBrush x:Key="Card3Border" Color="#5A4F3B"/>
    <SolidColorBrush x:Key="Card4Bg" Color="#2A3D32"/>
    <SolidColorBrush x:Key="Card4Border" Color="#3D5947"/>
    <SolidColorBrush x:Key="Card5Bg" Color="#332A44"/>
    <SolidColorBrush x:Key="Card5Border" Color="#4A3D66"/>
    <SolidColorBrush x:Key="Card6Bg" Color="#3D3A27"/>
    <SolidColorBrush x:Key="Card6Border" Color="#5A553B"/>
    <SolidColorBrush x:Key="Card7Bg" Color="#2A3D3A"/>
    <SolidColorBrush x:Key="Card7Border" Color="#3D5953"/>

    <!-- Theme toggle icon -->
    <sys:String x:Key="ThemeToggleIcon" xmlns:sys="clr-namespace:System;assembly=mscorlib">☀️</sys:String>

</ResourceDictionary>
